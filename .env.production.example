# Used by docker-compose.prod.yml (laravel, queue, scheduler, postgres, redis).
# Copy to .env.production and fill in real values — never commit the copy.

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=FutureKawa
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=futurekawa
DB_USERNAME=futurekawa
DB_PASSWORD=change-me

# ── Cache & Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@futurekawa.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Admin account (created on first boot) ────────────────────────────────────
ADMIN_NAME="Administrateur"
ADMIN_EMAIL=admin@futurekawa.local
ADMIN_PASSWORD=change-me

# ── Webhook security token ────────────────────────────────────────────────────
WEBHOOK_TOKEN=change-me-to-a-strong-random-token

# ── Sanctum ──────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost
SESSION_DRIVER=cookie
SESSION_DOMAIN=localhost

# Generate with: docker run --rm futurekawa-backend:latest php artisan key:generate --show
APP_KEY=
