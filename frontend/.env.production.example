# Used by docker-compose.prod.yml (frontend service only).
# Copy to .env.production and point it at wherever the backend actually
# runs — this is the ONLY thing the frontend needs to talk to the backend.
# It never gets zone credentials or any backend secret.
#
# Injected into the running container at startup and written to
# /env-config.js (see frontend/docker-entrypoint.sh) — no image rebuild
# needed to repoint an already-built frontend at a different backend.

API_URL=http://localhost:8000/api
