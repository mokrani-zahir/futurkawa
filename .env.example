# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=FutureKawa
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=futurekawa
DB_USERNAME=futurekawa
DB_PASSWORD=secret

# ── Cache & Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@futurekawa.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Admin account (created on first boot) ────────────────────────────────────
ADMIN_NAME="Administrateur"
ADMIN_EMAIL=admin@futurekawa.local
ADMIN_PASSWORD=changeme123

# ── Webhook security token ────────────────────────────────────────────────────
# Shared secret sent by external APIs in the Authorization header
WEBHOOK_TOKEN=change-me-to-a-strong-random-token

# ── Sanctum ──────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost
SESSION_DRIVER=cookie
SESSION_DOMAIN=localhost

# Left empty on purpose: generated automatically on first `docker-compose up`
# (see backend/docker-entrypoint.sh). Do not commit a real key.
APP_KEY=
