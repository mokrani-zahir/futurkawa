<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="./vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!--
            The laravel service is started with `env_file: .env` in docker-compose.yml,
            which injects the dev database credentials as real OS environment variables.
            Laravel's Dotenv loader is immutable and never overrides an already-set env
            var, so a .env.testing file alone cannot redirect the DB connection here.
            PHPUnit itself defaults to the same non-overriding behaviour for <env> — it
            only takes precedence over an already-set variable when force="true" is set.
        -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="DB_DATABASE" value="futurekawa_test" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="WEBHOOK_TOKEN" value="test-webhook-token" force="true"/>
    </php>
</phpunit>
