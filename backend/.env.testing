APP_NAME=FutureKawa
APP_ENV=testing
APP_KEY=base64:8jcQRe0Mu98dpn69PFMUKePjaoww8ldHJtS65kYlA3M=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Same Postgres server as the dev container, but a dedicated database so the
# test suite never touches development data. Created automatically by
# docker-entrypoint.sh on container start.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=futurekawa_test
DB_USERNAME=futurekawa
DB_PASSWORD=secret

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

SESSION_DRIVER=array
CACHE_STORE=array

MAIL_MAILER=array

WEBHOOK_TOKEN=test-webhook-token
